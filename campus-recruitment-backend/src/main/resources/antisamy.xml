<?xml version="1.0" encoding="UTF-8"?>
<anti-samy-rules xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                 xsi:noNamespaceSchemaLocation="antisamy.xsd">

    <directives>
        <directive name="omitXmlDeclaration" value="true"/>
        <directive name="omitDoctypeDeclaration" value="true"/>
        <directive name="maxInputSize" value="200000"/>
        <directive name="formatOutput" value="true"/>
        <directive name="embedStyleSheets" value="false"/>
    </directives>

    <common-regexps>
        <regexp name="htmlTitle" value="[a-zA-Z0-9\s\-_',:\[\]!\./\\\(\)&amp;]*"/>
        <regexp name="cssColor" value="(\#\p{XDigit}{3,8})|\p{XDigit}{3,8}|rgb\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*\)|rgba\(\s*\d+\s*,\s*\d+\s*,\s*\d+\s*,\s*[\d.]+\s*\)"/>
    </common-regexps>

    <common-attributes>
        <attribute name="lang" description="The lang attribute">
            <regexp-list>
                <regexp name="htmlTitle"/>
            </regexp-list>
        </attribute>
        <attribute name="title" description="The title attribute">
            <regexp-list>
                <regexp name="htmlTitle"/>
            </regexp-list>
        </attribute>
        <attribute name="href" description="The href attribute">
            <regexp-list>
                <regexp value="(\s)*(javascript:|vbscript:|data:).*" negate="true"/>
            </regexp-list>
        </attribute>
        <attribute name="align" description="The align attribute">
            <regexp-list>
                <regexp value="center|left|right|justify|char"/>
            </regexp-list>
        </attribute>
        <attribute name="style" description="The style attribute">
            <regexp-list>
                <regexp value=".*"/>
            </regexp-list>
        </attribute>
        <attribute name="class" description="The class attribute">
            <regexp-list>
                <regexp name="htmlTitle"/>
            </regexp-list>
        </attribute>
    </common-attributes>

    <global-tag-attributes>
        <attribute name="title"/>
        <attribute name="lang"/>
        <attribute name="class"/>
        <attribute name="style"/>
    </global-tag-attributes>

    <tags-to-encode>
        <tag>script</tag>
        <tag>iframe</tag>
        <tag>object</tag>
        <tag>embed</tag>
        <tag>applet</tag>
        <tag>form</tag>
        <tag>input</tag>
        <tag>button</tag>
        <tag>textarea</tag>
        <tag>select</tag>
    </tags-to-encode>

    <tag-rules>
        <tag name="p" action="validate">
            <attribute name="align"/>
        </tag>
        <tag name="br" action="validate"/>
        <tag name="b" action="validate"/>
        <tag name="i" action="validate"/>
        <tag name="u" action="validate"/>
        <tag name="strong" action="validate"/>
        <tag name="em" action="validate"/>
        <tag name="span" action="validate"/>
        <tag name="div" action="validate">
            <attribute name="align"/>
        </tag>
        <tag name="h1" action="validate"/>
        <tag name="h2" action="validate"/>
        <tag name="h3" action="validate"/>
        <tag name="h4" action="validate"/>
        <tag name="h5" action="validate"/>
        <tag name="h6" action="validate"/>
        <tag name="ul" action="validate"/>
        <tag name="ol" action="validate"/>
        <tag name="li" action="validate"/>
        <tag name="a" action="validate">
            <attribute name="href"/>
            <attribute name="target">
                <regexp-list>
                    <regexp value="_blank|_self"/>
                </regexp-list>
            </attribute>
            <attribute name="rel">
                <regexp-list>
                    <regexp value="noopener|noreferrer|nofollow"/>
                </regexp-list>
            </attribute>
        </tag>
        <tag name="img" action="validate">
            <attribute name="src">
                <regexp-list>
                    <regexp value="(\s)*(javascript:|vbscript:|data:).*" negate="true"/>
                </regexp-list>
            </attribute>
            <attribute name="alt">
                <regexp-list>
                    <regexp name="htmlTitle"/>
                </regexp-list>
            </attribute>
            <attribute name="width">
                <regexp-list>
                    <regexp value="\d+%?"/>
                </regexp-list>
            </attribute>
            <attribute name="height">
                <regexp-list>
                    <regexp value="\d+%?"/>
                </regexp-list>
            </attribute>
        </tag>
        <tag name="table" action="validate">
            <attribute name="width"/>
            <attribute name="border"/>
            <attribute name="cellspacing"/>
            <attribute name="cellpadding"/>
        </tag>
        <tag name="thead" action="validate"/>
        <tag name="tbody" action="validate"/>
        <tag name="tfoot" action="validate"/>
        <tag name="tr" action="validate"/>
        <tag name="th" action="validate">
            <attribute name="colspan"/>
            <attribute name="rowspan"/>
        </tag>
        <tag name="td" action="validate">
            <attribute name="colspan"/>
            <attribute name="rowspan"/>
        </tag>
        <tag name="blockquote" action="validate"/>
        <tag name="hr" action="validate"/>
        <tag name="pre" action="validate"/>
        <tag name="code" action="validate"/>
    </tag-rules>

    <css-rules>
        <property name="color" description="CSS color property">
            <regexp-list>
                <regexp name="cssColor"/>
            </regexp-list>
        </property>
        <property name="background-color" description="CSS background-color property">
            <regexp-list>
                <regexp name="cssColor"/>
            </regexp-list>
        </property>
        <property name="font-size" description="CSS font-size property">
            <regexp-list>
                <regexp value="\d+(px|em|pt|%)?"/>
            </regexp-list>
        </property>
        <property name="text-align" description="CSS text-align property">
            <regexp-list>
                <regexp value="left|center|right|justify"/>
            </regexp-list>
        </property>
        <property name="font-weight" description="CSS font-weight property">
            <regexp-list>
                <regexp value="normal|bold|\d{3}"/>
            </regexp-list>
        </property>
        <property name="font-style" description="CSS font-style property">
            <regexp-list>
                <regexp value="normal|italic"/>
            </regexp-list>
        </property>
        <property name="text-decoration" description="CSS text-decoration property">
            <regexp-list>
                <regexp value="none|underline|line-through"/>
            </regexp-list>
        </property>
        <property name="margin" description="CSS margin property">
            <regexp-list>
                <regexp value="\d+(px|em|pt|%)?(\s+\d+(px|em|pt|%)?){0,3}"/>
            </regexp-list>
        </property>
        <property name="padding" description="CSS padding property">
            <regexp-list>
                <regexp value="\d+(px|em|pt|%)?(\s+\d+(px|em|pt|%)?){0,3}"/>
            </regexp-list>
        </property>
    </css-rules>
</anti-samy-rules>
